{
  "manifest_version": 3,
  "name": "MissAV Quick Viewer",
  "version": "1.3",
  "description": "Search and filter structured data",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://missav.ws/*"],
      "js": ["db.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
