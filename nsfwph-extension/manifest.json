{
  "manifest_version": 7,
  "name": "nsfwPH Extension",
  "description": "Automatically shows floating panel for .message-inner video elements",
  "version": "1.7",
  "action": {
    "default_title": "nsfwph.org Video Observer (Floating Panel)"
  },
  "content_scripts": [
    {
      "matches": ["https://nsfwph.org/*"],
      "js": ["content.js", "gallery.js"],
      "css": ["panel.css", "gallery.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "host_permissions": ["https://nsfwph.org/*"]
}
