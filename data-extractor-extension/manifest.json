{
  "manifest_version": 3,
  "name": "Smart Data Extractor",
  "version": "1.3",
  "description": "Extract + watch any data with live HTML preview",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Data Extractor"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
